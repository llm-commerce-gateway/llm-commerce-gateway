  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "clean": "git clean -xdf .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "prepublishOnly": "pnpm build",
    "test": "vitest run --config vitest.oss.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:watch": "vitest tests/e2e",
    "test:oss": "vitest run --config vitest.oss.config.ts",
    "test:oss:watch": "vitest --config vitest.oss.config.ts",
    "lint": "tsc --noEmit",
    "check:contract": "npx tsx scripts/check-contract.ts && node ../../scripts/check-oss-boundary.mjs --package packages/commerce-gateway",
    "check:oss-boundary": "node ../../scripts/check-oss-boundary.mjs --package packages/commerce-gateway"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@t3-oss/env-nextjs": "^0.11.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "commander": "^11.1.0",
    "hono": "^4.5.3",
    "jose": "^5.10.0",
    "ora": "^7.0.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "supertest": "^6.3.3",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^1.0.0"
  },
