# ============================================================================
# LLM Gateway - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider API Keys
# ----------------------------------------------------------------------------

# Anthropic Claude (for MCP and API)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ChatGPT (for Function Calling)
OPENAI_API_KEY=sk-...

# Grok (X.AI)
GROK_API_KEY=grok_...

# Google Gemini
GOOGLE_API_KEY=...

# ----------------------------------------------------------------------------
# Session Management (Redis)
# ----------------------------------------------------------------------------

# Upstash Redis (recommended for production)
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-redis-token

# Or standard Redis
# REDIS_URL=redis://localhost:6379

# Session TTL in seconds (default: 86400 = 24 hours)
SESSION_TTL=86400

# ----------------------------------------------------------------------------
# Gateway Authentication
# ----------------------------------------------------------------------------

# API Key for gateway access (comma-separated for multiple keys)
API_KEY=your-gateway-api-key-here

# JWT Secret for OAuth flows
JWT_SECRET=your-jwt-secret-min-32-chars

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------

# Port to run the gateway on
PORT=3000

# Node environment
NODE_ENV=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------------------------------------------------
# Lightweight Ingestion - Shopify
# ----------------------------------------------------------------------------

# Your Shopify store domain (without https://)
SHOPIFY_DOMAIN=mystore.myshopify.com

# Shopify Admin API access token
# Get from: Shopify Admin > Apps > Develop apps > Create an app
SHOPIFY_ACCESS_TOKEN=shpat_...

# ----------------------------------------------------------------------------
# Lightweight Ingestion - Square
# ----------------------------------------------------------------------------

# Square access token
# Get from: https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=...

# Square location ID (optional, for inventory)
SQUARE_LOCATION_ID=...

# Use sandbox environment (true/false)
SQUARE_SANDBOX=false

# ----------------------------------------------------------------------------
# Optional: Link Generation (Dub.co)
# ----------------------------------------------------------------------------

# Dub.co API key
# Get from: https://dub.co/settings/tokens
DUB_API_KEY=dub_...

# Your custom domain on Dub.co
DUB_DOMAIN=yourdomain.com

# ----------------------------------------------------------------------------
# Optional: Database (PostgreSQL)
# ----------------------------------------------------------------------------

# PostgreSQL connection string (if using Prisma backend)
DATABASE_URL=postgresql://user:password@localhost:5432/llm_gateway

# ----------------------------------------------------------------------------
# Optional: Observability
# ----------------------------------------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=https://...@sentry.io/...

# Datadog API key for metrics
DATADOG_API_KEY=...

# ----------------------------------------------------------------------------
# Development
# ----------------------------------------------------------------------------

# Enable debug logging
DEBUG=llm-gateway:*

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Pretty print logs in development
LOG_PRETTY=true

