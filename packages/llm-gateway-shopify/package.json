{
  "name": "@betterdata/commerce-gateway-shopify",
  "version": "1.0.0",
  "description": "Shopify connector for the Better Data LLM Gateway - Storefront API integration",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@betterdata/commerce-gateway": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "llm",
    "gateway",
    "shopify",
    "commerce",
    "ecommerce",
    "connector",
    "storefront",
    "api"
  ],
  "publishConfig": {
    "access": "public"
  }
}