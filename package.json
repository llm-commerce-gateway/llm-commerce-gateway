{
  "name": "llm-commerce-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Universal LLM Commerce Gateway — federated product discovery across any storefront",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './commerce-registry-protocol' build",
    "test": "pnpm -r --filter './packages/**' run test --if-present",
    "typecheck": "pnpm -r --filter './packages/**' run typecheck --if-present",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "pnpm": {
    "overrides": {
      "@betterdata/commerce-gateway@^1.0.0": "workspace:*"
    }
  },
  "devDependencies": {
    "pnpm": "^9.15.9",
    "typescript": "^5.8.2"
  }
}
