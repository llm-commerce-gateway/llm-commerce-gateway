# Registry URL — Commerce Gateway Registry for brand/gateway resolution.
# Health check fetches {REGISTRY_URL}/.well-known/commerce-gateway.json
# Resolution order: this env var > gateway.config.json registryUrl > default
REGISTRY_URL=https://registry.betterdata.co

# Optional: App base URL for Status panel fetch (SSR/relative).
# Used when status page fetches /api/status; set for non-root deployments
# NEXT_PUBLIC_APP_URL=https://console.example.com
