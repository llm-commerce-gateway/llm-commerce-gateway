# ──────────────────────────────────────────────────────────────────────────────
# commerce-chat-ui — LLM chat over a Commerce Gateway
# ──────────────────────────────────────────────────────────────────────────────
# Provider selection is strictly env-driven. There is no UI toggle.

# ── LLM provider ─────────────────────────────────────────────────────────────
# One of: anthropic | openai | xai
LLM_PROVIDER=anthropic

# Optional model override. Safe defaults per provider:
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
#   xai       → grok-4-0709
# LLM_MODEL=

# ── API keys (only the one matching LLM_PROVIDER is required) ────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# ── Commerce Gateway target ──────────────────────────────────────────────────
# Point at any Commerce Gateway that honors POST /api/gateway/query.
# The bundled examples/demo-gateway runs at :3003 by default.
GATEWAY_BASE_URL=http://localhost:3003
GATEWAY_API_TOKEN=dev-token
