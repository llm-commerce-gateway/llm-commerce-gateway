# ──────────────────────────────────────────────────────────────────────────────
# demo-gateway — OSS Commerce Gateway reference
# ──────────────────────────────────────────────────────────────────────────────

# Bearer token required on POST /api/gateway/query. Any value works locally;
# use something long and random in shared environments.
DEMO_GATEWAY_TOKEN=dev-token

# Data source selection. `demo` (default) serves the bundled LUXE BOND JSON.
# `custom` proxies to a backend of your choice (see below).
DATA_SOURCE=demo

# ── DATA_SOURCE=demo ─────────────────────────────────────────────────────────
# Optional override for the bundled JSON path. Defaults to
# ../demo-data/luxe-bond/products.json (relative to this app's cwd).
# DEMO_DATA_PATH=../demo-data/luxe-bond/products.json

# ── DATA_SOURCE=custom ───────────────────────────────────────────────────────
# Your backend must accept POST {query: string} -> {products: GatewayProduct[]}.
# CUSTOM_DATA_SOURCE_URL=https://catalog.example.com
# CUSTOM_DATA_SOURCE_TOKEN=
# CUSTOM_DATA_SOURCE_QUERY_PATH=/search
# CUSTOM_DATA_SOURCE_COUNT_PATH=/count
